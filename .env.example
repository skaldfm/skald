# Skald configuration
# Copy to .env and uncomment/edit as needed.

# Server port
#SKALD_PORT=7707

# Data directory (database, uploads, backups)
#SKALD_DATA_DIR=./data

# Database type. Only "sqlite" is implemented today; PostgreSQL is not wired up.
#SKALD_DB_TYPE=sqlite

# Database connection string (SQLite path). Defaults to {SKALD_DATA_DIR}/skald.db
#SKALD_DB_URL=

# Send Secure cookies (session + CSRF). Default true; set to false only when
# serving plain HTTP directly (e.g. a LAN IP without a TLS-terminating proxy).
#SKALD_SECURE_COOKIES=true

# Automatic backup frequency (Go duration: 24h, 12h, 1h, etc.). 0 disables.
#SKALD_BACKUP_INTERVAL=24h

# Number of backups to retain before pruning old ones
#SKALD_BACKUP_RETAIN=14

# Allow self-service account registration (new users get viewer role)
#SKALD_OPEN_REGISTRATION=false

# Docker only: run the container process as a specific user/group
#PUID=1000
#PGID=1000
