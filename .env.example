# Skald configuration
# Copy to .env and uncomment/edit as needed.

# Server port
#SKALD_PORT=7707

# Data directory (database, uploads, backups)
#SKALD_DATA_DIR=./data

# Database type (sqlite or postgres)
#SKALD_DB_TYPE=sqlite

# Database connection string
# For SQLite: defaults to {SKALD_DATA_DIR}/skald.db
# For PostgreSQL: e.g. postgres://user:pass@localhost/skald
#SKALD_DB_URL=

# Session signing key (auto-generated if empty)
#SKALD_SECRET_KEY=

# Automatic backup frequency (Go duration: 24h, 12h, 1h, etc.)
#SKALD_BACKUP_INTERVAL=24h

# Number of backups to retain before pruning old ones
#SKALD_BACKUP_RETAIN=14

# Allow self-service account registration (new users get viewer role)
#SKALD_OPEN_REGISTRATION=false

# Docker only: run the container process as a specific user/group
#PUID=1000
#PGID=1000
